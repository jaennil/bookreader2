{
  "name": "polka-book-reader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "go run ./backend/cmd/server",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "test": "npm run test:api && npm run build",
    "test:api": "cd backend && GOCACHE=/tmp/bookreader-go-cache go test ./...",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "esbuild": "^0.28.1"
  }
}
